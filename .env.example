# ============================================================
# Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_ENV=development
DEBUG=true

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard Settings
DASHBOARD_PORT=8501

# MLflow Settings
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=fraud_detection

# Model Settings
MODEL_PATH=./models
DATA_PATH=./data
REPORTS_PATH=./reports

# Dataset paths (download from Kaggle)
# https://www.kaggle.com/datasets/mlg-ulb/creditcardfraud
CREDITCARD_CSV=data/creditcard.csv
# https://www.kaggle.com/datasets/ealaxi/paysim1
PAYSIM_CSV=data/PS_20174392719_1491204439457_log.csv
